generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  video Video[]
  summaries VideoSummary[]
  questions VideoQuestion[]
  chatMessages ChatMessage[]
}

model Video{
  id String @id @default(uuid())
  userId String
  user  User @relation(fields: [userId], references: [id],onDelete: Cascade)
  videoId String 
  videoUrl String
  title String?
  thumbnail String?
  namespace   String @unique
  totalChunks Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  summaries    VideoSummary[]
  questions    VideoQuestion[]
  chatMessages ChatMessage[]
  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

model VideoSummary{
  id String @id @default(uuid())
  videoRefId String
  video  Video @relation(fields: [videoRefId], references: [id],onDelete: Cascade)
  userId String
  user  User @relation(fields: [userId], references: [id],onDelete: Cascade)
  shortSummary      String   @db.Text
  longSummary       String   @db.Text
  keypointSummary   Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, videoRefId])
  @@index([userId])
  @@index([videoRefId])
}

model VideoQuestion {
  id String @id @default(uuid())
  videoRefId String
  video  Video @relation(fields: [videoRefId], references: [id],onDelete: Cascade)
  userId String
  user  User @relation(fields: [userId], references: [id],onDelete: Cascade)
  easyQuestions     Json
  mediumQuestions   Json
  hardQuestions     Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, videoRefId])
  @@index([userId])
  @@index([videoRefId])
}

model ChatMessage {
  id String @id @default(uuid())
  videoRefId String
  video  Video @relation(fields: [videoRefId], references: [id],onDelete: Cascade)
  userId String
  user  User @relation(fields: [userId], references: [id],onDelete: Cascade)
  role String
  text String @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([videoRefId])
}
